root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]
indent_size = 4

[*.{css,js,json,html,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{csproj,props,targets,slnx}]
indent_size = 2

[Dockerfile]
indent_size = 4
