# Merlin Configuration
# Copy to .env and adjust as needed

# Host filesystem paths (mounted into container)
HOST_PROC_PATH=/host/proc
HOST_SYS_PATH=/host/sys
HOST_ROOT_PATH=/host/root

# Container runtime socket
PODMAN_SOCKET_PATH=/var/run/podman/podman.sock

# Web server
ASPNETCORE_URLS=http://+:5050

# Persistence
MERLIN_DB_PATH=./data/merlin.db
MERLIN_RETENTION_DAYS=7

# Homepage
MERLIN_HOMEPAGE_CONFIG=./data/homepage.json

# Discord Alerts (leave empty to disable)
MERLIN_DISCORD_WEBHOOK_URL=
MERLIN_ALERT_CPU_THRESHOLD=90
MERLIN_ALERT_MEM_THRESHOLD=90
MERLIN_ALERT_DISK_THRESHOLD=95
MERLIN_ALERT_COOLDOWN_MINUTES=15
